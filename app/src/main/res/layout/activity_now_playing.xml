<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/np_bg">

    <!-- Blurred/background album art (dimmed) -->
    <ImageView
        android:id="@+id/np_album_art_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.15"
        android:src="@drawable/ic_music_note"
        android:contentDescription="@string/album_art" />

    <!-- Gradient overlay at bottom -->
    <View
        android:id="@+id/np_overlay"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_bottom"
        android:visibility="gone" />

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="24dp">

        <!-- LEFT: Album Art + Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center">

                <ImageView
                    android:id="@+id/np_album_art"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_music_note"
                    android:alpha="0.9"
                    android:contentDescription="@string/album_art" />

                <!-- Disc shadow ring -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/disc_ring"
                    android:alpha="0.3" />
            </FrameLayout>

            <!-- Track info below album art -->
            <TextView
                android:id="@+id/np_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="20sp"
                android:textColor="@color/np_text_primary"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Song Title"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/np_artist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="16sp"
                android:textColor="@color/np_text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Artist" />

            <TextView
                android:id="@+id/np_album"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="13sp"
                android:textColor="@color/np_text_hint"
                android:maxLines="1"
                android:ellipsize="end"
                android:text=" " />

            <!-- SeekBar + Time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <SeekBar
                    android:id="@+id/np_seekbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progressDrawable="@drawable/seekbar_progress_np"
                    android:thumb="@drawable/seekbar_thumb_np" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/np_time_current"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="11sp"
                        android:textColor="@color/np_text_hint"
                        android:text="0:00" />

                    <TextView
                        android:id="@+id/np_time_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/np_text_hint"
                        android:text="0:00" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- RIGHT: Lyrics -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:orientation="vertical"
            android:layout_marginStart="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/np_lyrics_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lyrics"
                android:textSize="12sp"
                android:textColor="@color/np_text_hint"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />

            <ScrollView
                android:id="@+id/np_lyrics_scroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:fadingEdge="vertical"
                android:requiresFadingEdge="vertical"
                android:fadingEdgeLength="48dp">

                <TextView
                    android:id="@+id/np_lyrics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="@color/np_lyrics_text"
                    android:lineSpacingExtra="8dp"
                    android:paddingStart="4dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="120dp"
                    android:visibility="gone" />
            </ScrollView>

            <!-- Playback Controls -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="8dp">

                <ImageButton
                    android:id="@+id/np_repeat"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_repeat"
                    android:alpha="0.3"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/repeat" />

                <ImageButton
                    android:id="@+id/np_shuffle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_shuffle"
                    android:alpha="0.4"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/shuffle"
                    android:layout_marginStart="4dp" />

                <ImageButton
                    android:id="@+id/np_prev"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_skip_previous"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/previous"
                    android:layout_marginStart="8dp" />

                <ImageButton
                    android:id="@+id/np_play"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_play_circle"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/play"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <ImageButton
                    android:id="@+id/np_next"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_skip_next"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/next" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Back button (top-left) -->
    <ImageButton
        android:id="@+id/np_back"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_margin="12dp"
        android:layout_gravity="start|top"
        android:src="@drawable/ic_arrow_back"
        android:background="@drawable/circle_bg_dark"
        android:alpha="0.7"
        android:contentDescription="@string/back" />
</FrameLayout>
